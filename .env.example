# ── Spring Profile ─────────────────────────────
# Options: dev | prod | docker
#   dev  = auto-create tables, debug logging
#   prod = validate only, warn logging
#   docker = used when app runs inside Docker Compose
SPRING_PROFILES_ACTIVE=dev

# ── Database ───────────────────────────────────
# Host and port for Postgres (use container name when inside Docker)
DB_HOST=localhost
DB_PORT=5435

# Database name, user, and password
POSTGRES_DB=mystudyapp
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme-strong-password-here

# ── JWT (must be >= 32 characters) ─────────────
# Generate a strong random string for production.
# Example generation: openssl rand -base64 32
JWT_SECRET=replace-me-with-a-256-bit-secret-key-min-32-chars!!

# ── App Ports ──────────────────────────────────
SERVER_PORT=8081
ASTA_SERVER_PORT=8082

# ── Frontend URL (for email links etc.) ────────
FRONTEND_URL=http://localhost:5173

# ── Email From Address ─────────────────────────
MAIL_FROM=noreply@mystudyapp.de

# ── MQTT (Mosquitto broker) ────────────────────
# Use container name when inside Docker: mqtt-broker or mosquitto
MQTT_HOST=localhost

# ── Email (Gmail SMTP) ─────────────────────────
# Gmail account for sending emails (use App Password, not regular password)
# To generate an App Password:
# 1. Go to your Google Account → Security → 2-Step Verification
# 2. Enable 2-Step Verification if not already enabled
# 3. Go to App Passwords (under 2-Step Verification)
# 4. Select "Mail" and your device, then generate
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx